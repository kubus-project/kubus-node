KUBUS_API_BASE_URL=http://host.docker.internal:3000
KUBUS_OPERATOR_TOKEN=replace-with-wallet-jwt
KUBUS_OPERATOR_WALLET=0x0000000000000000000000000000000000000000
KUBUS_NODE_LABEL=kubus-availability-node-1
KUBUS_NODE_ENDPOINT_URL=http://127.0.0.1:8080
IPFS_RPC_URL=http://kubo:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080
LOCAL_STATE_PATH=/var/lib/kubus-node/state.json
LOG_LEVEL=info
HEARTBEAT_INTERVAL_MS=60000
CID_SYNC_INTERVAL_MS=300000
COMMITMENT_INTERVAL_MS=900000
STATUS_INTERVAL_MS=120000
MAX_PINNED_CIDS=100
CID_CLASS_FILTERS=hot,warm
NODE_ENV=development

# Optional
KUBUS_NODE_KEY=
KUBUS_AUTH_MODE=bearer
KUBUS_DEV_SEED_CID=
KUBUS_DEV_ALLOW_EMPTY_CIDS=true
KUBUS_SKIP_PINNING=false
KUBUS_VERIFIER_ENDPOINT_URL=
