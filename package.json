{
  "name": "@kubus/kubus-node",
  "version": "0.1.0",
  "description": "Kubus Availability Network operator runtime",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "kubus-node": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts start",
    "start": "node dist/src/index.js start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "status": "tsx src/index.ts status",
    "doctor": "tsx src/index.ts doctor",
    "gui": "tsx src/index.ts gui",
    "smoke": "tsx scripts/smoke.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
